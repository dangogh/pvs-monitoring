#!/usr/bin/make -f

include /usr/share/dpkg/architecture.mk

DESTDIR ?= debian/pvs-monitoring
export PATH := $(HOME)/go/bin:$(PATH)

%:
	dh $@ --without usrlocal --without dwz

# DEB_HOST_ARCH (arm64/amd64) matches Go's GOARCH naming for our supported
# targets, so it can be passed straight through. Only dh_auto_build cross-
# compiles for the host arch; dh_auto_test below builds/runs natively so
# tests don't require emulation.
override_dh_auto_build:
	GOOS=linux GOARCH=$(DEB_HOST_ARCH) CGO_ENABLED=0 go build -buildvcs=false -ldflags="-s -w" -o bin/pvs-monitor ./cmd/pvs-monitor
	GOOS=linux GOARCH=$(DEB_HOST_ARCH) CGO_ENABLED=0 go build -buildvcs=false -ldflags="-s -w" -o bin/pvs-api ./cmd/pvs-api
	GOOS=linux GOARCH=$(DEB_HOST_ARCH) CGO_ENABLED=0 go build -buildvcs=false -ldflags="-s -w" -o bin/pvs-ui ./cmd/pvs-ui

override_dh_auto_install:
	# Install binaries
	install -D -m 755 bin/pvs-monitor $(DESTDIR)/usr/bin/pvs-monitor
	install -D -m 755 bin/pvs-api $(DESTDIR)/usr/bin/pvs-api
	install -D -m 755 bin/pvs-ui $(DESTDIR)/usr/bin/pvs-ui
	
	# Install systemd services
	install -D -m 644 debian/pvs-monitor.service $(DESTDIR)/etc/systemd/system/pvs-monitor.service
	install -D -m 644 debian/pvs-api.service $(DESTDIR)/etc/systemd/system/pvs-api.service
	install -D -m 644 debian/pvs-ui.service $(DESTDIR)/etc/systemd/system/pvs-ui.service
	
	# Install example config (as both the example and the default live config)
	install -D -m 644 config.example.yaml $(DESTDIR)/etc/pvs-monitor/config.yaml.example
	install -D -m 644 config.example.yaml $(DESTDIR)/etc/pvs-monitor/config.yaml.dpkg-new

	# Install update script
	install -D -m 755 pvs-update.sh $(DESTDIR)/usr/bin/pvs-update

	# Install sudoers drop-in for passwordless deployment
	install -D -m 440 debian/pvs-monitor.sudoers $(DESTDIR)/etc/sudoers.d/pvs-monitor

override_dh_auto_test:
	go test ./...

override_dh_strip:
	# Skip stripping for Go binaries

override_dh_makeshlibs:
	# Static Go binaries (CGO_ENABLED=0) have no shared library dependencies,
	# and running this needs a cross-arch objdump we don't install.

override_dh_shlibdeps:
	# Same reasoning as dh_makeshlibs above.
