FROM debian:bookworm

RUN apt-get update -q && \
    apt-get install -y --no-install-recommends \
        curl git build-essential devscripts debhelper ca-certificates fakeroot && \
    curl -fsSL https://go.dev/dl/go1.26.4.linux-arm64.tar.gz | tar -C /usr/local -xz && \
    useradd -m builder

ENV PATH="/usr/local/go/bin:${PATH}"

COPY --chown=builder:builder . /build
USER builder
WORKDIR /build
